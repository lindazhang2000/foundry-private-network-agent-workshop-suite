{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "_description": "Minimal Azure Cosmos DB for NoSQL account aligned with the private-network Foundry agent workshop guide. Serverless, AAD-only, public network disabled. The capability host provisioner uses the project managed identity (granted Cosmos DB Operator + SQL Built-in Data Contributor) to create the required containers."
    },
    "parameters": {
        "databaseAccountName": {
            "type": "String",
            "defaultValue": "<cosmos-account-name>"
        },
        "location": {
            "type": "String",
            "defaultValue": "eastus",
            "metadata": {
                "description": "Azure region. Should match the rest of the Foundry stack unless quota forces another region."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.DocumentDB/databaseAccounts",
            "apiVersion": "2024-11-15",
            "name": "[parameters('databaseAccountName')]",
            "location": "[parameters('location')]",
            "kind": "GlobalDocumentDB",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "databaseAccountOfferType": "Standard",
                "publicNetworkAccess": "Disabled",
                "disableLocalAuth": true,
                "disableKeyBasedMetadataWriteAccess": true,
                "minimalTlsVersion": "Tls12",
                "networkAclBypass": "None",
                "enableAutomaticFailover": false,
                "enableMultipleWriteLocations": false,
                "consistencyPolicy": {
                    "defaultConsistencyLevel": "Session"
                },
                "capabilities": [
                    {
                        "name": "EnableServerless"
                    }
                ],
                "locations": [
                    {
                        "locationName": "[parameters('location')]",
                        "failoverPriority": 0,
                        "isZoneRedundant": false
                    }
                ],
                "ipRules": [],
                "virtualNetworkRules": [],
                "backupPolicy": {
                    "type": "Continuous",
                    "continuousModeProperties": {
                        "tier": "Continuous7Days"
                    }
                }
            }
        }
    ],
    "outputs": {
        "cosmosAccountId": {
            "type": "string",
            "value": "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('databaseAccountName'))]"
        },
        "documentEndpoint": {
            "type": "string",
            "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('databaseAccountName'))).documentEndpoint]"
        }
    }
}
